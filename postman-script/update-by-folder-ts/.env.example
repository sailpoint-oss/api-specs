POSTMAN_API_KEY=your-postman-api-key-here

# AWS credentials for DynamoDB access.
# Option 1: explicit keys (any IAM user/role with PutItem on the CMS table)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_SESSION_TOKEN=your-session-token   # only needed for temporary/assumed-role credentials
AWS_REGION=us-east-1

# Option 2: use a named AWS CLI profile instead of the keys above.
# Set this and leave the key variables unset; the SDK will load ~/.aws/credentials.
# AWS_PROFILE=your-profile-name
