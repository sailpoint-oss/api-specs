    "_postman_id": "65f2643b-8da6-47f0-a824-b9b32879cba5",
    "name": "SailPoint Identity Security Cloud - OAuth & SAML",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "OAuth 2.0 and SAML endpoints for authentication and token management. Use this spec to generate a Postman collection with correct URLs (tenant + domain, no version path).",
      "type": "text/plain"
    }
  },
  "auth": {
